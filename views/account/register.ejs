<% if (title) { %>
    <h1>
        <%= title %>
    </h1>
<% } else { res.redirect('/') } %>

<%- messages() %>

<% if (errors) { %>
  <ul class="notice">
 <% errors.array().forEach(error => { %>
   <li><%= error.msg %></li>
<%  }) %>
 </ul>
<% } %>

<form class="login-form" action="/account/register" method="post">
  <label for="first-name">First Name:</label>
  <input type="text" name="account_firstname" id="first-name" required/>
  <label for="last-name">Last Name:</label>
  <input type="text" name="account_lastname" id="last-name" required/>
  <label for="email">Email Address:</label>
  <input type="email" name="account_email" id="email" required/>
  <label for="password">Password:</label>
  <input type="password" name="account_password" id="password" required pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$">
  <span>Passwords must be at least 12 characters and contain at least 1 number, 1 capital letter and 1 special character</span>
  <button>REGISTER</button>
</form>