<% if (title) { %>
    <h1>
        <%= title %>
    </h1>
<% } else { res.redirect('/') } %>

<%- messages() %>

<% if (errors) { %>
  <ul class="notice">
 <% errors.array().forEach(error => { %>
   <li><%= error.msg %></li>
<%  }) %>
 </ul>
<% } %>

<form action="/inv/classification" method="post">
    <p>FIELD IS REQUIRED</p>
    <label for="classification">Classification Name</label>
    <input type="text" id="classification" name="classification_name" pattern="^[a-zA-Z]+$" required>
    
    <span>NAME MUST BE ALPHABETIC CHARACTERS ONLY, NO SPACES OR SPECIAL CHARACTERS</span>
    <button>Add Classification</button>
</form>