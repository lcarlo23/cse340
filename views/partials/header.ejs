<header id="top-header">
  <span class="siteName">
    <a href="/" title="Return to home page">CSE Motors</a>
  </span>
  <div id="tools">
    <% if (typeof loggedin != "undefined" && loggedin) { %>
      <a title="Click to access the account manager" href="/account/">Welcome <%= accountData.account_firstname %></a>
      <a title="Click to log out" href="/account/logout">LOGOUT</a>
    <% } else { %>
      <a title="Click to log in" href="/account/login">MY ACCOUNT</a>
    <% } %>
  </div>
</header>
